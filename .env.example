# Copy to .env for local testing (do not commit .env)

# Required: your QWeather API Host, e.g. https://abc123.qweatherapi.com
QWEATHER_API_HOST=

# Option A: paste a freshly generated JWT (expires quickly, good for local test)
QWEATHER_JWT=

# Option B: auto-generate JWT in CI (recommended for GitHub Actions)
QWEATHER_KID=
QWEATHER_PROJECT_ID=
QWEATHER_PRIVATE_KEY=

# Optional overrides
QWEATHER_LOCATION_ID=101020100
QWEATHER_LAT=31.23
QWEATHER_LON=121.47
CITY_NAME=上海
KINDLE_WIDTH=1072
KINDLE_HEIGHT=1448
TZ=Asia/Shanghai
